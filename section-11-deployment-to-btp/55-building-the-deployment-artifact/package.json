{
  "name": "cap-event-management",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "^3.12.0",
    "@cap-js/audit-logging": ">=0",
    "@cap-js/change-tracking": "^1.2.1",
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sap/ux-specification": "^1.144.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "globalSetup": "./test/setup.ts",
    "testEnvironment": "node",
    "testTimeout": 20000
  },
  "private": true,
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "sapux": [
    "app/event-management"
  ],
  "cds": {
    "requires": {
      "html5-repo": true,
      "[production]": {
        "auth": "xsuaa"
      },
      "API_BUSINESS_PARTNER": {
        "kind": "odata-v2",
        "model": "srv/external/API_BUSINESS_PARTNER",
        "[hybrid]": {
          "credentials": {
            "destination": "S4HANA_SANDBOX",
            "path": "/sap/opu/odata/sap/API_BUSINESS_PARTNER"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "S4HANA_SANDBOX",
            "path": "/sap/opu/odata/sap/API_BUSINESS_PARTNER"
          }
        }
      },
      "messaging": {
        "kind": "enterprise-messaging",
        "format": "cloudevents",
        "[development]": {
          "kind": "file-based-messaging"
        }
      }
    },
    "hana": {
      "fuzzy": 0.7
    }
  }
}
